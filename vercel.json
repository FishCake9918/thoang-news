{
  "functions": {
    "index.php": { "runtime": "vercel-php@0.7.1" },
    "api/*.php": { "runtime": "vercel-php@0.7.1" }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.php" },
    { "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.php" }
  ]
}